# filename: .dockerignore
# purpose:  Exclude files from Docker build context (infrastructure.md requirement)

# Large data — never in image
data/raw/
data/processed/

# ML artifacts — mounted as volumes at runtime
mlruns/
mlflow.db
models/*.pkl
models/*.joblib

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# Version control
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp

# Secrets
.env
.env.*

# Notebooks (not needed at runtime)
notebooks/

# Docs
docs/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# OS artifacts
.DS_Store
Thumbs.db

!data/processed/sample_batch_template.csv
